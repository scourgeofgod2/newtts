# ─────────────────────────────────────────────
# metinseslendirme.com — Environment Variables
# ─────────────────────────────────────────────
# Kopyala: cp .env.example .env
# Coolify'da bu değerleri Environment Variables bölümüne gir.
# Kod içine KESİNLİKLE ekleme.

# CortexAI (router.claude.gg) API anahtarı — zorunlu
CORTEXAI_API_KEY=your_cortexai_api_key_here

# Sunucu portu — Coolify otomatik ayarlar, genellikle değiştirme
PORT=3000